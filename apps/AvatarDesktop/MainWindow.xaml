<Window x:Class="AvatarDesktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Avatar Desktop Prototype (LM Studio + USD-ready)"
        Width="1280"
        Height="820"
        MinWidth="1080"
        MinHeight="720"
        WindowStartupLocation="CenterScreen"
        Background="#EEF3F8"
        Loaded="Window_Loaded"
        Closing="Window_Closing">
    <Grid Margin="12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.25*" />
            <ColumnDefinition Width="8" />
            <ColumnDefinition Width="1.75*" />
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Column="0" Margin="0,0,12,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <GroupBox Header="3D Avatar Scene (WPF USD Mesh View, cube fallback)" Grid.Row="0">
                <Border Background="#10141A" CornerRadius="6" Padding="4">
                    <ContentControl x:Name="AvatarViewportHost" />
                </Border>
            </GroupBox>

            <GroupBox Header="Avatar Response Text" Grid.Row="1" Margin="0,10,0,0">
                <TextBox x:Name="ModelTextOutputTextBox"
                         IsReadOnly="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         Height="110"
                         Background="#0F0F10"
                         Foreground="#EDEDED"
                         BorderBrush="#333"
                         Padding="8" />
            </GroupBox>

            <Border Grid.Row="2"
                    Margin="0,10,0,0"
                    Padding="10"
                    CornerRadius="6"
                    BorderBrush="#3A3A3A"
                    BorderThickness="1"
                    Background="#14181F">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="State:" Foreground="#C8D2E1" VerticalAlignment="Center" Margin="0,0,8,0" />
                    <TextBlock x:Name="AvatarStateTextBlock" Text="Idle" Foreground="#FFFFFF" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,18,0" />
                    <TextBlock Text="Renderer:" Foreground="#C8D2E1" VerticalAlignment="Center" Margin="0,0,8,0" />
                    <TextBlock x:Name="RendererInfoTextBlock"
                               Text="WPF USD mesh view (cube fallback, USD not selected yet)"
                               Foreground="#FFFFFF"
                               VerticalAlignment="Center" />
                </StackPanel>
            </Border>
        </Grid>

        <GridSplitter Grid.Column="1"
                      Width="8"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Stretch"
                      Background="#D4DCE7"
                      ShowsPreview="True" />

        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <GroupBox Header="LM Studio Settings" Grid.Row="0">
                <Grid Margin="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="150" />
                        <ColumnDefinition Width="120" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Text="Base URL" Margin="0,0,8,8" />
                    <TextBox x:Name="BaseUrlTextBox" Grid.Row="0" Grid.Column="1" Margin="0,0,8,8" />

                    <TextBlock Grid.Row="0" Grid.Column="2" VerticalAlignment="Center" Text="Model" Margin="0,0,8,8" />
                    <TextBox x:Name="ModelTextBox" Grid.Row="0" Grid.Column="3" Margin="0,0,0,8" />

                    <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Text="Temperature" Margin="0,0,8,0" />
                    <TextBox x:Name="TemperatureTextBox" Grid.Row="1" Grid.Column="1" Margin="0,0,8,0" />

                    <TextBlock Grid.Row="1" Grid.Column="2" VerticalAlignment="Center" Text="Max Tokens" Margin="0,0,8,0" />
                    <TextBox x:Name="MaxTokensTextBox" Grid.Row="1" Grid.Column="3" />

                    <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Text="Run Mode" Margin="0,8,8,0" />
                    <CheckBox x:Name="OfflineDemoModeCheckBox"
                              Grid.Row="2"
                              Grid.Column="1"
                              Grid.ColumnSpan="3"
                              Margin="0,8,0,0"
                              IsChecked="True"
                              Checked="OfflineDemoModeCheckBox_Changed"
                              Unchecked="OfflineDemoModeCheckBox_Changed"
                              Content="Offline Demo Mode (no LM Studio, local JSON command emulation)" />
                </Grid>
            </GroupBox>

            <Border Grid.Row="1"
                    Margin="0,10,0,0"
                    Padding="10"
                    CornerRadius="6"
                    BorderBrush="#DDDDDD"
                    BorderThickness="1"
                    Background="#F8F8F8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Border x:Name="ConnectionStatusBadge"
                            Width="14"
                            Height="14"
                            CornerRadius="7"
                            Background="#9AA0A6"
                            BorderBrush="#555"
                            BorderThickness="1"
                            VerticalAlignment="Center"
                            Margin="0,0,8,0" />
                    <TextBlock x:Name="ConnectionStatusTextBlock"
                               Grid.Column="1"
                               VerticalAlignment="Center"
                               Text="LM Studio status: unknown" />
                    <Button x:Name="HealthCheckButton"
                            Grid.Column="2"
                            Margin="8,0,8,0"
                            Padding="12,6"
                            Click="HealthCheckButton_Click"
                            Content="Health Check (/models)" />
                    <Button x:Name="WidgetModeButton"
                            Grid.Column="3"
                            Margin="0,0,8,0"
                            Padding="12,6"
                            Click="WidgetModeButton_Click"
                            Content="Start Widget" />
                    <Button x:Name="ChatGptVoiceButton"
                            Grid.Column="4"
                            Margin="0,0,8,0"
                            Padding="12,6"
                            Click="ChatGptVoiceButton_Click"
                            Content="ChatGPT Voice..." />
                    <Button x:Name="LoadUsdHookButton"
                            Grid.Column="5"
                            Padding="12,6"
                            Click="LoadUsdHookButton_Click"
                            Content="Reload Avatar USD" />
                </Grid>
            </Border>

            <GroupBox Header="Send Prompt to LM Studio" Grid.Row="2" Margin="0,10,0,0">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBox x:Name="UserInputTextBox"
                             Grid.Row="0"
                             Grid.Column="0"
                             Margin="0,0,8,8"
                             Padding="8"
                             MinHeight="64"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             VerticalContentAlignment="Top"
                             VerticalScrollBarVisibility="Auto"
                             ToolTip="Enter = Send, Shift+Enter = new line"
                             KeyDown="UserInputTextBox_KeyDown" />
                    <Button x:Name="SendButton"
                            Grid.Row="0"
                            Grid.Column="1"
                            Padding="18,8"
                            Click="SendButton_Click"
                            Content="Send" />

                    <TextBlock Grid.Row="1"
                               Grid.ColumnSpan="2"
                               Foreground="#666"
                               Text="Enter = Send. Shift+Enter = new line. In LM Studio mode, model should return JSON only (text, mood, action, duration_ms)." />
                </Grid>
            </GroupBox>

            <GroupBox Header="Logs" Grid.Row="3" Margin="0,10,0,0">
                <ListBox x:Name="LogsListBox"
                         FontFamily="Consolas"
                         FontSize="12"
                         Background="#0F1114"
                         Foreground="#E9EDF2"
                         BorderBrush="#2B3037"
                         Padding="6" />
            </GroupBox>
        </Grid>
    </Grid>
</Window>
