<Window x:Class="AvatarDesktop.WidgetWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Avatar Widget"
        Width="420"
        Height="420"
        MinWidth="180"
        MinHeight="180"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        Loaded="Window_Loaded"
        KeyDown="Window_KeyDown">
    <Grid Background="Transparent">
        <ContentControl x:Name="WidgetViewportHost" />

        <Ellipse x:Name="DragHandle"
                 Width="16"
                 Height="16"
                 Fill="#B0FFFFFF"
                 Stroke="#70000000"
                 StrokeThickness="1"
                 HorizontalAlignment="Right"
                 VerticalAlignment="Top"
                 Margin="8"
                 Cursor="SizeAll"
                 MouseLeftButtonDown="DragHandle_MouseLeftButtonDown" />
    </Grid>
</Window>
