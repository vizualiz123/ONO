<Window x:Class="AvatarDesktop.VoiceChatWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ChatGPT Voice (OpenAI API)"
        Width="840"
        Height="740"
        MinWidth="760"
        MinHeight="640"
        WindowStartupLocation="CenterOwner"
        Background="#EEF3F8"
        Loaded="Window_Loaded"
        Closing="Window_Closing">
    <Window.Resources>
        <Style TargetType="GroupBox">
            <Setter Property="Margin" Value="0,0,0,0" />
            <Setter Property="Padding" Value="0" />
        </Style>
        <Style TargetType="Button">
            <Setter Property="MinHeight" Value="32" />
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="MinHeight" Value="28" />
        </Style>
    </Window.Resources>
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <GroupBox Header="OpenAI / ChatGPT API" Grid.Row="0">
            <Grid Margin="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="120" />
                    <ColumnDefinition Width="140" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Text="Base URL" Margin="0,0,8,8" />
                <TextBox x:Name="ApiBaseUrlTextBox" Grid.Row="0" Grid.Column="1" Margin="0,0,8,8" />
                <TextBlock Grid.Row="0" Grid.Column="2" VerticalAlignment="Center" Text="Chat Model" Margin="0,0,8,8" />
                <TextBox x:Name="ApiModelTextBox" Grid.Row="0" Grid.Column="3" Margin="0,0,0,8" />

                <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Text="API Key" Margin="0,0,8,8" />
                <PasswordBox x:Name="ApiKeyPasswordBox" Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="3" Margin="0,0,0,8" />

                <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Text="STT Model" Margin="0,0,8,8" />
                <TextBox x:Name="TranscriptionModelTextBox" Grid.Row="2" Grid.Column="1" Margin="0,0,8,8" />
                <TextBlock Grid.Row="2" Grid.Column="2" VerticalAlignment="Center" Text="STT Lang" Margin="0,0,8,8" />
                <TextBox x:Name="TranscriptionLanguageTextBox" Grid.Row="2" Grid.Column="3" Margin="0,0,0,8" ToolTip="Optional: ru, en, etc." />

                <TextBlock Grid.Row="3" Grid.Column="0" VerticalAlignment="Center" Text="TTS Model" Margin="0,0,8,0" />
                <TextBox x:Name="TtsModelTextBox" Grid.Row="3" Grid.Column="1" Margin="0,0,8,0" />
                <TextBlock Grid.Row="3"
                           Grid.Column="2"
                           VerticalAlignment="Center"
                           Text="TTS Voice (ChatGPT)"
                           Margin="0,0,8,0"
                           Visibility="Collapsed" />
                <ComboBox x:Name="TtsVoiceTextBox"
                          Grid.Row="3"
                          Grid.Column="3"
                          IsEditable="True"
                          IsTextSearchEnabled="True"
                          ToolTip="Built-in OpenAI TTS voices for gpt-4o-mini-tts"
                          Visibility="Collapsed" />
            </Grid>
        </GroupBox>

        <GroupBox Header="Generation Settings" Grid.Row="1" Margin="0,10,0,0">
            <Grid Margin="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="120" />
                    <ColumnDefinition Width="140" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="Temperature" Margin="0,0,8,0" />
                <TextBox x:Name="ApiTemperatureTextBox" Grid.Column="1" Margin="0,0,8,0" />
                <TextBlock Grid.Column="2" VerticalAlignment="Center" Text="Max Tokens" Margin="0,0,8,0" />
                <TextBox x:Name="ApiMaxTokensTextBox" Grid.Column="3" Margin="0,0,8,0" />
                <Button x:Name="TestConnectionButton"
                        Grid.Column="4"
                        Padding="12,6"
                        Click="TestConnectionButton_Click"
                        Content="Test API (/models)" />
            </Grid>
        </GroupBox>

        <GroupBox Header="Realtime Dialog (Low Latency, ChatGPT-like)" Grid.Row="2" Margin="0,10,0,0">
            <Grid Margin="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border x:Name="RealtimeStatusBadge"
                        Grid.Row="0"
                        Grid.Column="0"
                        Width="14"
                        Height="14"
                        CornerRadius="7"
                        Background="#9AA0A6"
                        BorderBrush="#555"
                        BorderThickness="1"
                        VerticalAlignment="Center"
                        Margin="0,0,8,0" />
                <TextBlock x:Name="RealtimeStatusTextBlock"
                           Grid.Row="0"
                           Grid.Column="1"
                           VerticalAlignment="Center"
                           Text="Realtime: disconnected" />

                <TextBlock Grid.Row="0" Grid.Column="2" Margin="12,0,8,0" VerticalAlignment="Center" Text="Model" Visibility="Collapsed" />
                <TextBox x:Name="RealtimeModelTextBox"
                         Grid.Row="0"
                         Grid.Column="3"
                         Width="140"
                         Margin="0,0,8,0"
                         IsReadOnly="True"
                         Visibility="Collapsed" />
                <TextBlock Grid.Row="0" Grid.Column="4" Margin="4,0,8,0" VerticalAlignment="Center" Text="Voice (ChatGPT)" />
                <ComboBox x:Name="RealtimeVoiceTextBox"
                          Grid.Row="0"
                          Grid.Column="5"
                          Width="120"
                          Margin="0,0,8,0"
                          IsEditable="True"
                          IsTextSearchEnabled="True" />
                <Button x:Name="RealtimeConnectButton"
                        Grid.Row="0"
                        Grid.Column="6"
                        Padding="12,6"
                        Click="RealtimeConnectButton_Click"
                        Content="Start Live Chat" />

                <Button x:Name="RealtimeDisconnectButton"
                        Grid.Row="1"
                        Grid.Column="2"
                        Margin="0,8,8,0"
                        Padding="12,6"
                        Click="RealtimeDisconnectButton_Click"
                        Content="Disconnect"
                        IsEnabled="False"
                        Visibility="Collapsed" />
                <Button x:Name="RealtimeMicOnButton"
                        Grid.Row="1"
                        Grid.Column="3"
                        Margin="0,8,8,0"
                        Padding="12,6"
                        Click="RealtimeMicOnButton_Click"
                        Content="Start Listening"
                        IsEnabled="False"
                        Visibility="Collapsed" />
                <Button x:Name="RealtimeMicOffButton"
                        Grid.Row="1"
                        Grid.Column="4"
                        Margin="0,8,8,0"
                        Padding="12,6"
                        Click="RealtimeMicOffButton_Click"
                        Content="Pause Mic"
                        IsEnabled="False"
                        Visibility="Collapsed" />
                <TextBlock Grid.Row="1"
                           Grid.Column="2"
                           Grid.ColumnSpan="5"
                           Margin="0,12,0,0"
                           Foreground="#666"
                           Text="Live chat starts with one button (connect + mic on). Choose the same voice name style as in ChatGPT. Voice changes apply immediately in live chat." />
            </Grid>
        </GroupBox>

        <GroupBox Header="Voice Turn (OpenAI STT + Chat + TTS, fallback)" Grid.Row="3" Margin="0,10,0,0">
            <Grid Margin="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border x:Name="ApiStatusBadge"
                        Grid.Row="0"
                        Grid.Column="0"
                        Width="14"
                        Height="14"
                        CornerRadius="7"
                        Background="#9AA0A6"
                        BorderBrush="#555"
                        BorderThickness="1"
                        VerticalAlignment="Center"
                        Margin="0,0,8,0" />
                <TextBlock x:Name="ApiStatusTextBlock"
                           Grid.Row="0"
                           Grid.Column="1"
                           VerticalAlignment="Center"
                           Text="Status: ready (enter API key)" />

                <Button x:Name="StartRecordButton"
                        Grid.Row="0"
                        Grid.Column="2"
                        Margin="8,0,8,0"
                        Padding="12,6"
                        Click="StartRecordButton_Click"
                        Content="Start Recording" />
                <Button x:Name="StopAndSendButton"
                        Grid.Row="0"
                        Grid.Column="3"
                        Margin="0,0,8,0"
                        Padding="12,6"
                        Click="StopAndSendButton_Click"
                        Content="Stop + Send"
                        IsEnabled="False" />
                <Button x:Name="CancelRecordButton"
                        Grid.Row="0"
                        Grid.Column="4"
                        Margin="0,0,8,0"
                        Padding="12,6"
                        Click="CancelRecordButton_Click"
                        Content="Cancel"
                        IsEnabled="False" />
                <Button x:Name="StopAudioButton"
                        Grid.Row="0"
                        Grid.Column="5"
                        Padding="12,6"
                        Click="StopAudioButton_Click"
                        Content="Stop Audio" />

                <TextBlock Grid.Row="1"
                           Grid.Column="0"
                           Grid.ColumnSpan="6"
                           Margin="0,8,0,0"
                           Foreground="#666"
                           Text="Use Start Recording, speak into microphone, then Stop + Send. ChatGPT transcript + response + voice are all handled via OpenAI API." />
            </Grid>
        </GroupBox>

        <GroupBox Header="Manual Text Test (same ChatGPT voice pipeline, but typed input)" Grid.Row="4" Margin="0,10,0,0">
            <Grid Margin="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox x:Name="ManualPromptTextBox"
                         Margin="0,0,8,0"
                         Padding="8"
                         MinHeight="56"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         VerticalContentAlignment="Top"
                         VerticalScrollBarVisibility="Auto"
                         ToolTip="Enter = Send, Shift+Enter = new line"
                         KeyDown="ManualPromptTextBox_KeyDown" />
                <Button x:Name="SendManualButton"
                        Grid.Column="1"
                        Padding="12,6"
                        Click="SendManualButton_Click"
                        Content="Send" />
            </Grid>
        </GroupBox>

        <Grid Grid.Row="5" Margin="0,10,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="6" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <GroupBox Header="Last Turn" Grid.Row="0">
                <TextBox x:Name="LastTurnTextBox"
                         Margin="8"
                         Height="110"
                         Padding="8"
                         IsReadOnly="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         Background="#0F1114"
                         Foreground="#E9EDF2"
                         BorderBrush="#2B3037" />
            </GroupBox>

            <GridSplitter Grid.Row="1"
                          Height="6"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Center"
                          Background="#D4DCE7"
                          ShowsPreview="True" />

            <GroupBox Header="Voice Logs" Grid.Row="2" Margin="0,8,0,0">
                <ListBox x:Name="VoiceLogsListBox"
                         FontFamily="Consolas"
                         FontSize="12"
                         Background="#0F1114"
                         Foreground="#E9EDF2"
                         BorderBrush="#2B3037"
                         Padding="6" />
            </GroupBox>
        </Grid>
    </Grid>
</Window>
